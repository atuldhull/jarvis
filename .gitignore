# Python virtual environment
.venv/

# Local working notes — kept out of the shipped project
CLAUDE.md

# The Playwright login profile (Phase 3) — holds cookies/sessions. NEVER commit.
profile/

# Real API keys for the model router — SECRETS. Only keys.example.json is shared.
keys.json
.env

# Local model files & caches
*.gguf
models/

# Voice models — big binaries, re-downloaded with one command (see README).
# The tiny .onnx.json configs stay in the repo so the voices are documented.
voices/*.onnx

# Local databases (long-term memory) + SQLite WAL sidecar files
*.db
*.db-wal
*.db-shm

# Audio scratch files (Phase 4)
*.wav

# Personal images dropped into the dashboard centre, and screenshots it takes —
# kept on your machine, not shared in the repo.
assets/user.*
assets/shots/

# Python noise
__pycache__/
*.pyc
.pytest_cache/
